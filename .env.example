# ============================================================
# Linux Hardening Assistant — Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# Server port (backend Express server)
# Using 3001 to avoid conflict with other local projects
PORT=3001

# Node environment (development | production)
NODE_ENV=development

# ── Google Gemini AI ─────────────────────────────────────────
# Get your API key from: https://aistudio.google.com/apikey
# If not set, the app automatically falls back to local rule-based analysis.
GEMINI_API_KEY=

# ── SSH settings ──────────────────────────────────────────────
# Connection timeout in milliseconds (default: 30 seconds)
SSH_TIMEOUT=30000

# Per-command execution timeout in milliseconds (default: 30 seconds)
SSH_COMMAND_TIMEOUT=30000

# ── Security ──────────────────────────────────────────────────
# Session / JWT secret — change this to a random string in production
JWT_SECRET=change-me-to-a-random-secret-string
SESSION_SECRET=change-me-to-another-random-secret

# ── Storage ───────────────────────────────────────────────────
# Directory where generated fix scripts are saved
# Default: ./reports (relative to project root)
REPORT_STORAGE=./reports
